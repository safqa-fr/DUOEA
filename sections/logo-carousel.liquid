{% schema %}
{
  "name": "Stats carousel",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Couleur fond", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Couleur texte", "default": "#000000" },
    { "type": "color", "id": "accent_color", "label": "Couleur accent (chiffres)", "default": "#C97A5D" },
    {
      "type": "range",
      "id": "section_height",
      "label": "Hauteur du fond (px)",
      "min": 40,
      "max": 200,
      "step": 5,
      "default": 90
    },
    { "type": "range", "id": "carousel_width", "label": "Largeur (%)", "min": 60, "max": 100, "step": 5, "default": 100 },
    { "type": "range", "id": "speed", "label": "Vitesse (sec)", "min": 10, "max": 70, "step": 5, "default": 30 },
    { "type": "range", "id": "gap", "label": "Espace (px)", "min": 10, "max": 80, "step": 5, "default": 60 },
    { "type": "range", "id": "font_size", "label": "Taille texte (px)", "min": 10, "max": 28, "step": 1, "default": 15 },
    { "type": "range", "id": "accent_size", "label": "Taille accent (px)", "min": 12, "max": 36, "step": 1, "default": 18 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "accent", "label": "Chiffre / Accent", "default": "782+" },
        { "type": "text", "id": "label", "label": "Texte descriptif", "default": "Happy Couples" },
        { "type": "text", "id": "separator", "label": "Séparateur", "default": "·" }
      ]
    }
  ],
  "presets": [{ "name": "Stats carousel" }]
}
{% endschema %}

<div class="sc-wrap"
     style="
       background: {{ section.settings.bg_color }};
       height: {{ section.settings.section_height }}px;
     ">

  <div class="sc-inner" style="max-width: {{ section.settings.carousel_width }}%;">

    <div class="sc-track">
      {% for block in section.blocks %}
        <div class="sc-item" {{ block.shopify_attributes }}>
          {% if block.settings.accent != blank %}
            <span class="sc-accent" style="font-size: {{ section.settings.accent_size }}px; color: {{ section.settings.accent_color }};">
              {{ block.settings.accent }}
            </span>
          {% endif %}
          {% if block.settings.label != blank %}
            <span class="sc-label" style="font-size: {{ section.settings.font_size }}px; color: {{ section.settings.text_color }};">
              {{ block.settings.label }}
            </span>
          {% endif %}
          {% if block.settings.separator != blank %}
            <span class="sc-sep" style="color: {{ section.settings.accent_color }}; font-size: {{ section.settings.accent_size }}px;">
              {{ block.settings.separator }}
            </span>
          {% endif %}
        </div>
      {% endfor %}

      {% for block in section.blocks %}
        <div class="sc-item">
          {% if block.settings.accent != blank %}
            <span class="sc-accent" style="font-size: {{ section.settings.accent_size }}px; color: {{ section.settings.accent_color }};">
              {{ block.settings.accent }}
            </span>
          {% endif %}
          {% if block.settings.label != blank %}
            <span class="sc-label" style="font-size: {{ section.settings.font_size }}px; color: {{ section.settings.text_color }};">
              {{ block.settings.label }}
            </span>
          {% endif %}
          {% if block.settings.separator != blank %}
            <span class="sc-sep" style="color: {{ section.settings.accent_color }}; font-size: {{ section.settings.accent_size }}px;">
              {{ block.settings.separator }}
            </span>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</div>

<style>
.sc-wrap {
  overflow: hidden;
  display: flex;
  align-items: center;
}

.sc-inner {
  margin: auto;
  overflow: hidden;
  width: 100%;
}

.sc-track {
  display: flex;
  align-items: center;
  gap: {{ section.settings.gap }}px;
  width: max-content;
  animation: sc-scroll linear infinite;
  animation-duration: {{ section.settings.speed }}s;
}

.sc-item {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
}

.sc-accent {
  font-weight: 700;
  line-height: 1;
}

.sc-label {
  font-weight: 500;
  line-height: 1;
}

.sc-sep {
  font-weight: 700;
  line-height: 1;
  margin-left: 4px;
}

@keyframes sc-scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
</style>
